generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  searches  SearchHistory[]
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  query     String
  type      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}